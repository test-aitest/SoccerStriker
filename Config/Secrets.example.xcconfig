// === Soccer Striker のシークレット設定（.env 相当）===
// このファイルをコピーして `Secrets.xcconfig` を作り、キーを記入してください:
//   cp Config/Secrets.example.xcconfig Config/Secrets.xcconfig
// Secrets.xcconfig は .gitignore 済みなので git に載りません。
// 値はビルド時に Info.plist (GeminiAPIKey) へ注入され、アプリが起動時に読みます。

// Gemini API キー（Google AI Studio で取得）
GEMINI_API_KEY =
